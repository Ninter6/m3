M3_EXPORT template <class T, class R = decltype(tan(std::declval<T>()))>
constexpr R cot(T a) { return R(1) / tan(a); }

M3_EXPORT constexpr auto fract(std::floating_point auto a) {
    return a - floor(a);
}

M3_EXPORT template <std::floating_point T>
[[nodiscard]] constexpr T radians(T angle) noexcept {
    return angle / T(180) * pi<T>;
}

