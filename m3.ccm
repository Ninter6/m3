template <class T, std::size_t N>
struct basic_vec {
    T as_array[N]{};

    constexpr auto operator<=>(const basic_vec& rhs) const = default;
};

template <class T>
struct basic_vec<T, 1> {
    union {
        struct { T x; };
        struct { T r; };
        struct { T i; };
        T as_array[1]{};
    };

    constexpr auto operator<=>(const basic_vec& rhs) const { return x <=> rhs.x; }
};

template <class T>
struct basic_vec<T, 2> {
    union {
        struct { T x, y; };
        struct { T r, g; };
        struct { T i, j; };
        T as_array[2]{};
    };

    constexpr auto operator<=>(const basic_vec& rhs) const {
        auto t = x <=> rhs.x;
        return t != 0 ? t : y <=> rhs.y;
    }
};

template <class T>
struct basic_vec<T, 3> {
    union {
        struct { T x, y, z; };
        struct { T r, g, b; };
        struct { T i, j, k; };
        T as_array[3]{};
    };

    constexpr auto operator<=>(const basic_vec& rhs) const {
        for (std::size_t i = 0; i < 3; ++i)
            if (auto t = as_array[i] <=> rhs.as_array[i]; t != 0)
                return t;
        return std::partial_ordering::equivalent;
    }
};

template <class T>
struct basic_vec<T, 4> {
    union {
        struct { T x, y, z, w; };
        struct { T r, g, b, a; };
        struct { T i, j, k, l; };
        T as_array[4]{};
    };

    constexpr auto operator<=>(const basic_vec& rhs) const {
        for (std::size_t i = 0; i < 4; ++i)
            if (auto t = as_array[i] <=> rhs.as_array[i]; t != 0)
                return t;
        return std::partial_ordering::equivalent;
    }
};

M3_EXPORT template <class T, std::size_t N>
struct vec : basic_vec<T, N> {
    using value_type = T;

    constexpr vec() = default;
    constexpr vec(std::common_with<T> auto&& ... args)
    requires (1 < sizeof...(args) && sizeof...(args) <= N) {
        [&]<std::size_t... I>(std::index_sequence<I...>) {
            (((*this)[I] = std::forward<decltype(args)>(args)), ...);
        }(std::make_index_sequence<sizeof...(args)>{});
    }
    constexpr explicit vec(std::common_with<T> auto&& a) {
        std::fill_n(begin(), N, std::forward<decltype(a)>(a));
    }
    template <std::common_with<T> U, std::size_t M, std::common_with<T>... Args>
    constexpr explicit vec(const vec<U, M>& u, Args&&... args)
    requires (sizeof...(Args) == 0) || (M + sizeof...(Args) <= N) {
        std::copy_n(u.begin(), min(M, N), begin());
        if constexpr (sizeof...(Args)) {
            [&]<std::size_t... I>(std::index_sequence<I...>) {
                (((*this)[M + I] = std::forward<Args>(args)), ...);
            }(std::index_sequence_for<Args...>{});
        }
    }

    constexpr auto size() const { return N; }

    constexpr T& operator[](std::size_t i) { assert(i < N); return (*this).as_array[i]; }
    constexpr const T& operator[](std::size_t i) const { assert(i < N); return (*this).as_array[i]; }

    constexpr auto value_ptr() { return (*this).as_array; }
    constexpr auto value_ptr() const { return (*this).as_array; }

    constexpr auto begin() { return (*this).as_array; }
    constexpr auto end() { return (*this).as_array + size(); }
    constexpr auto cbegin() const { return (*this).as_array; }
    constexpr auto cend() const { return (*this).as_array + size(); }
    constexpr auto begin() const { return cbegin(); }
    constexpr auto end() const { return cend(); }

    using basic_vec<T, N>::operator<=>;
    constexpr bool operator==(const vec& o) const {
        for (std::size_t i = 0; i < N; ++i)
            if ((*this)[i] != o[i])
                return false;
        return true;
    }

    constexpr T sum() const {
        return std::accumulate(begin(), end(), T{});
    }
    constexpr T length_squared() const {
        return std::transform_reduce(begin(), end(), T{},
            std::plus{}, [](auto&& i) {return i*i;});
    }
    constexpr T length() const { return sqrt(length_squared()); }

    constexpr void normalize() { (*this) /= length(); }
    constexpr auto normalized() const { return (*this) / length(); }

    constexpr void renorm(const T& n) { (*this) *= n / length(); }

    template<size_t I>
    decltype(auto) get() & { return (*this)[I]; }
    template<size_t I>
    decltype(auto) get() const& { return (*this)[I]; }
    template<size_t I>
    decltype(auto) get() && { return std::move((*this)[I]); }

};

template <class T, class... Args>
requires (sizeof...(Args) > 0) && (std::common_with<T, Args> && ...)
vec(T, Args...) -> vec<T, 1 + sizeof...(Args)>;

template <class T, std::size_t N, class... Args>
requires (std::common_with<T, Args> && ...)
vec(vec<T, N>, Args...) -> vec<T, N + sizeof...(Args)>;

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator+(const vec<T, N>& v) {
    return v;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator-(const vec<T, N>& v) {
    auto r = v;
    for (auto& i : r) i = -i;
    return r;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator+=(vec<T, N>& lhs, const vec<T, N>& rhs) {
    for (std::size_t i = 0; i < N; ++i)
        lhs[i] += rhs[i];
    return lhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator+(const vec<T, N>& lhs, const vec<T, N>& rhs) {
    auto r = lhs;
    return r += rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator-=(vec<T, N>& lhs, const vec<T, N>& rhs) {
    for (std::size_t i = 0; i < N; ++i)
        lhs[i] -= rhs[i];
    return lhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator-(const vec<T, N>& lhs, const vec<T, N>& rhs) {
    auto r = lhs;
    return r -= rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator+=(vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    for (std::size_t i = 0; i < N; ++i)
        lhs[i] += rhs;
    return lhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator+(const vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    auto r = lhs;
    return r += rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator-=(vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    return lhs += -rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator-(const vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    return lhs + -rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator*=(vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    for (std::size_t i = 0; i < N; ++i)
        lhs[i] *= rhs;
    return lhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator*(const vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    auto r = lhs;
    return r *= rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator*(std::common_with<T> auto&& lhs, const vec<T, N>& rhs) {
    return rhs * std::forward<decltype(lhs)>(lhs);
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto& operator/=(vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    return lhs *= T(1) / rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator/(const vec<T, N>& lhs, std::common_with<T> auto&& rhs) {
    auto r = lhs;
    return r /= rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto operator/(std::common_with<T> auto&& lhs, const vec<T, N>& rhs) {
    return vec<T, N>{lhs} / rhs;
}

M3_EXPORT template <class T, std::size_t N>
constexpr T sum(const vec<T, N>& v) {
    return std::accumulate(v.begin(), v.end(), T{});
}

M3_EXPORT template <class T, std::size_t N>
constexpr T length_squared(const vec<T, N>& v) {
    return v.length_squared();
}

M3_EXPORT template <class T, std::size_t N>
constexpr T length(const vec<T, N>& v) {
    return v.length();
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto normalize(const vec<T, N>& v) {
    return v.normalized();
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto norm(const vec<T, N>& v) {
    return v.length();
}

M3_EXPORT template <class T, std::size_t N>
constexpr auto renorm(vec<T, N> v, const T& n) {
    return v.renorm(n), v;
}

